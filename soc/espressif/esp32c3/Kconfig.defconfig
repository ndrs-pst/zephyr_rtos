if SOC_SERIES_ESP32C3

config NUM_IRQS
	default 32

config SYS_CLOCK_HW_CYCLES_PER_SEC
	default $(dt_node_int_prop_int, /cpus/cpu@0, clock-frequency)

config MAIN_STACK_SIZE
	default 2048

endif # SOC_SERIES_ESP32C3
